# ====== TEMEL ======
# Calisma modu: paper (sahte para, gercek fiyat) | testnet (Binance test sunucusu) | live (GERCEK PARA)
MODE=paper

# Panele giris icin gizli anahtar (uzun ve rastgele yap). WS ve butonlar bunu ister.
DASH_TOKEN=cok-uzun-rastgele-bir-sifre-yaz

# Sunucu portu (Render/Railway otomatik atar; lokal icin 8080)
PORT=8080

# ====== BINANCE API (sadece testnet/live icin gerekli) ======
# Binance > API Management'tan olustur. SADECE "Spot Trading" izni ver.
# "Enable Withdrawals" ASLA isaretleme. IP kisitlamasi koy (sunucunun IP'si).
BINANCE_KEY=
BINANCE_SECRET=

# ====== STRATEJI / RISK ======
QUOTE=USDT
START_CASH=50            # paper modda baslangic bakiyesi
UNIVERSE=40              # islem yapilacak en yuksek hacimli coin sayisi (max ~60)
MAX_POSITIONS=4          # ayni anda acik pozisyon
RISK_MODE=normal         # safe | normal | degen
POLL_MS=6000             # karar dongusu (ms)
MIN_NOTIONAL=10          # tek islem min buyuklugu (USDT). Binance min ~5-10.
DAILY_LOSS_STOP=0.15     # gun ici %15 kayipta otomatik DURUR (kill-switch)
MAX_TRADE_USDT=1000      # tek islemde harcanabilecek mutlak ust sinir (guvenlik)
